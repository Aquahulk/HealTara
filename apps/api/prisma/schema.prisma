generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     Int                @id @default(autoincrement())
  email                  String             @unique
  password               String
  role                   String
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  managedDoctorProfileId Int?               @map("managed_doctor_profile_id")
  managedHospitalId      Int?               @map("managed_hospital_id")
  canLogin               Boolean            @default(true) @map("can_login")
  status                 String             @default("ACTIVE") // ACTIVE, SUSPENDED
  adminAuditLogs         AdminAuditLog[]
  doctorAppointments     Appointment[]      @relation("DoctorAppointments")
  patientAppointments    Appointment[]      @relation("PatientAppointments")
  doctorEngagements      DoctorEngagement[] @relation("UserDoctorEngagements")
  doctorProfile          DoctorProfile?     @relation("UserDoctorProfile")
  patientProfile         PatientProfile?
  adminHospitals         Hospital[]         @relation("UserAdminHospitals")
  hospitalMemberships    HospitalDoctor[]   @relation("UserHospitalDoctor")
  doctorSlots            Slot[]             @relation("UserDoctorSlots")
  managedDoctorProfile   DoctorProfile?     @relation("UserManagedDoctorProfile", fields: [managedDoctorProfileId], references: [id])
  managedHospital        Hospital?          @relation("UserManagedHospital", fields: [managedHospitalId], references: [id])
  savedItems             SavedItem[]

  @@map("users")
}

model SavedItem {
  id         Int      @id @default(autoincrement())
  userId     Int
  entityType String   // 'doctor' or 'hospital'
  entityId   Int      // ID of the doctor or hospital
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, entityId])
  @@index([userId])
}

model DoctorProfile {
  id                Int                  @id @default(autoincrement())
  userId            Int                  @unique @map("user_id")
  specialization    String
  qualifications    String?
  experience        Int?
  clinicName        String?              @map("clinic_name")
  clinicAddress     String               @map("clinic_address")
  city              String?
  state             String?
  phone             String
  consultationFee   Int                  @map("consultation_fee")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  slug              String?              @unique
  slotPeriodMinutes Int                  @default(15) @map("slot_period_minutes")
  previousSlotPeriodMinutes Int?        @map("previous_slot_period_minutes")
  slotPeriodUpdatedAt DateTime?          @map("slot_period_updated_at")
  micrositeEnabled  Boolean              @default(true) @map("microsite_enabled")
  profileImage      String?              @map("profile_image")
  registrationNumber String?             @map("registration_number")
  verificationSubmitted Boolean          @default(false) @map("verification_submitted")
  verificationStatus String              @default("PENDING") @map("verification_status") // PENDING, APPROVED, REJECTED
  user              User                 @relation("UserDoctorProfile", fields: [userId], references: [id], onDelete: Cascade)
  timeOffs          DoctorTimeOff[]
  workingHours      DoctorWorkingHours[]
  slotAdmins        User[]               @relation("UserManagedDoctorProfile")

  @@map("doctor_profiles")
}

model PatientProfile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique @map("user_id")
  name        String?
  age         Int?
  gender      String?
  phone       String?
  address     String?
  city        String?
  state       String?
  bloodGroup  String?  @map("blood_group")
  allergies   String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("patient_profiles")
}

model DoctorTimeOff {
  id              Int           @id @default(autoincrement())
  doctorProfileId Int           @map("doctor_profile_id")
  start           DateTime
  end             DateTime
  reason          String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  @@map("doctor_time_offs")
}

model DoctorWorkingHours {
  id              Int           @id @default(autoincrement())
  doctorProfileId Int           @map("doctor_profile_id")
  dayOfWeek       Int           @map("day_of_week")
  startTime       String        @map("start_time")
  endTime         String        @map("end_time")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  @@unique([doctorProfileId, dayOfWeek])
  @@map("doctor_working_hours")
}

model Appointment {
  id        Int      @id @default(autoincrement())
  date      DateTime @map("appointment_date")
  status    String   @default("PENDING")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  doctorId  Int      @map("doctor_id")
  patientId Int      @map("user_id")
  notes     String?
  time      String
  doctor    User     @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Cascade)
  patient   User     @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)

  @@index([doctorId, date, status])
  @@index([patientId, date])
  @@index([date, time])
  @@map("appointments")
}

model Hospital {
  id          Int              @id @default(autoincrement())
  name        String
  subdomain   String?          @unique
  address     String?
  city        String?
  state       String?
  phone       String?
  profile     Json?
  status      String           @default("ACTIVE") // ACTIVE, SUSPENDED, PENDING
  registrationNumberGov String? @map("registration_number_gov")
  verificationSubmitted Boolean @default(false) @map("verification_submitted")
  verificationStatus    String  @default("PENDING") @map("verification_status") // PENDING, APPROVED, REJECTED
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  adminId     Int?             @map("admin_id")
  departments Department[]
  admin       User?            @relation("UserAdminHospitals", fields: [adminId], references: [id])
  doctors     HospitalDoctor[]
  slotAdmins  User[]           @relation("UserManagedHospital")

  @@map("hospitals")
}

model Department {
  id          Int              @id @default(autoincrement())
  hospitalId  Int              @map("hospital_id")
  name        String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  hospital    Hospital         @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  doctors     HospitalDoctor[]

  @@map("departments")
}

model HospitalDoctor {
  id           Int         @id @default(autoincrement())
  hospitalId   Int         @map("hospital_id")
  doctorId     Int         @map("doctor_id")
  departmentId Int?        @map("department_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  department   Department? @relation(fields: [departmentId], references: [id])
  doctor       User        @relation("UserHospitalDoctor", fields: [doctorId], references: [id], onDelete: Cascade)
  hospital     Hospital    @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@unique([hospitalId, doctorId])
  @@map("hospital_doctors")
}

model Slot {
  id        Int      @id @default(autoincrement())
  doctorId  Int      @map("doctor_id")
  date      DateTime
  time      String
  status    String   @default("AVAILABLE")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  doctor    User     @relation("UserDoctorSlots", fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, date, time])
  @@index([doctorId, date, status])
  @@index([date, status])
  @@index([status, time])
  @@map("slots")
}

model AdminAuditLog {
  id         Int      @id @default(autoincrement())
  adminId    Int      @map("admin_id")
  action     String
  entityType String   @map("entity_type")
  entityId   Int?     @map("entity_id")
  details    String?
  createdAt  DateTime @default(now()) @map("created_at")
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_audit_logs")
}

model DoctorEngagement {
  id         Int      @id @default(autoincrement())
  doctorId   Int      @map("doctor_id")
  date       DateTime @default(now())
  cardViews  Int      @default(0) @map("card_views")
  siteClicks Int      @default(0) @map("site_clicks")
  bookClicks Int      @default(0) @map("book_clicks")
  doctor     User     @relation("UserDoctorEngagements", fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, date])
  @@map("doctor_engagements")
}

model SearchAnalytics {
  id                 Int      @id @default(autoincrement())
  query              String
  normalizedQuery    String   @map("normalized_query")
  matchedConditions  String[] @map("matched_conditions")
  matchedSpecialties String[] @map("matched_specialties")
  topRankedDoctorId  Int?     @map("top_ranked_doctor_id")
  clickedDoctorId    Int?     @map("clicked_doctor_id")
  meta               Json?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([normalizedQuery])
  @@index([topRankedDoctorId])
  @@index([clickedDoctorId])
  @@map("search_analytics")
}

model Comment {
  id          Int       @id @default(autoincrement())
  entityType  String    @map("entity_type")
  entityId    String    @map("entity_id")
  userId      Int?      @map("user_id")
  name        String
  email       String
  rating      Int?
  comment     String
  parentId    Int?      @map("parent_id")
  isVerified  Boolean   @default(true) @map("is_verified")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedBy   Int?      @map("deleted_by")

  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[] @relation("CommentReplies")

  @@index([entityType, entityId])
  @@map("comments")
}
